-- ================= منطق الدروب كيك (من الكود الثاني) =================
local COOLDOWN = 1
local lastUse = 0
local busy = false

local function updateCooldownDisplay()
    while busy do
        local remaining = COOLDOWN - (tick() - lastUse)
        if remaining > 0 then
            cooldownLabel.Text = "Cooldown: " .. string.format("%.1f", remaining)
        else
            cooldownLabel.Text = "Ready ⚡"
            busy = false
            button.Text = "DROPKICK"
        end
        task.wait(0.1)
    end
end

-- دالة تنفيذ الدروب كيك الفعلية (مأخوذة من الكود الثاني مع تحسينات)
local function performDropkick(targetModel)
    if busy then return false end  -- في كولداون
    
    local character = player.Character
    if not character then
        player.CharacterAdded:Wait()
        character = player.Character
    end
    
    local humanoid = character:FindFirstChild("Humanoid")
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not humanoid or not rootPart then return false end
    
    local targetHumanoid = targetModel:FindFirstChild("Humanoid")
    if not targetHumanoid or targetHumanoid.Health <= 0 then return false end
    
    -- بدء الكولداون
    lastUse = tick()
    busy = true
    button.Text = "FIRING 💥"
    task.spawn(updateCooldownDisplay)
    
    -- تحميل وتشغيل الأنيميشن
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://10385907483"
    local animTrack = humanoid:LoadAnimation(anim)
    animTrack:Play()
    
    -- التحرك نحو الهدف
    local tween = TweenService:Create(rootPart, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {
        CFrame = targetModel:GetPivot() * CFrame.new(0, 0, -3)
    })
    tween:Play()
    tween.Completed:Wait()
    
    -- تطبيق القذف والإصابة
    targetHumanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    targetHumanoid:ChangeState(Enum.HumanoidStateType.Physics)
    if targetHumanoid.RootPart then
        targetHumanoid.RootPart.Velocity = Vector3.new(0, 20, 50)
    end
    
    targetHumanoid.Health = math.max(0, targetHumanoid.Health - 35)
    
    task.wait(1)
    targetHumanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, true)
    animTrack:Stop()
    
    return true
end

-- دالة مساعدة للحصول على الهدف من الماوس
local function getTargetFromMouse()
    local mouse = player:GetMouse()
    local targetPart = mouse.Target
    if targetPart and targetPart.Parent then
        local characterModel = targetPart.Parent
        if characterModel:FindFirstChild("Humanoid") and characterModel ~= player.Character then
            return characterModel
        end
    end
    return nil
end

