-- ================= Logic (Dropkick) =================
local COOLDOWN = 1
local lastUse = 0
local busy = false

-- Animation (fake dropkick)
local function setupAnimation(character)
    local humanoid = character:WaitForChild("Humanoid")
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://10385907483" -- actual dropkick animation
    local animTrack = humanoid:LoadAnimation(anim)
    return animTrack
end

local function dropkick(target, animTrack)
    if not target or not target:IsA("Model") then return false end
    local targetHumanoid = target:FindFirstChild("Humanoid")
    if not targetHumanoid or targetHumanoid.Health <= 0 then return false end
    
    local character = player.Character
    if not character then return false end
    local rootPart = character:FindFirstChild("HumanoidRootPart")
    if not rootPart then return false end
    
    -- Play animation
    animTrack:Play()
    
    -- Move player towards target (if needed)
    local tweenInfo = TweenInfo.new(0.2, Enum.EasingStyle.Linear)
    local tween = TweenService:Create(rootPart, tweenInfo, {CFrame = target:GetPivot() * CFrame.new(0, 0, -3)})
    tween:Play()
    tween.Completed:Wait()
    
    -- Apply force to target
    local velocity = Vector3.new(0, 20, 50) -- upward and forward
    targetHumanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, false)
    targetHumanoid:ChangeState(Enum.HumanoidStateType.Physics)
    if targetHumanoid.RootPart then
        targetHumanoid.RootPart.Velocity = velocity
    end
    
    -- Damage
    local damage = 35
    targetHumanoid.Health = math.max(0, targetHumanoid.Health - damage)
    
    -- Reset after 1 second
    task.wait(1)
    if targetHumanoid and targetHumanoid.Parent then
        targetHumanoid:SetStateEnabled(Enum.HumanoidStateType.Physics, true)
    end
    animTrack:Stop()
    return true
end

